{
  "$schema": "https://tr.designtokens.org/format/",
  "color": {
    "$description": "Paleta completa de June DS",
    "foundation": {
      "$description": "Colores base de marca",
      "fuchsia-500":      { "$value": "#E02B58", "$type": "color" },
      "fuchsia-700":      { "$value": "#D2285D", "$type": "color" },
      "blue-500":         { "$value": "#0F62FE", "$type": "color" },
      "royal-blue-500":   { "$value": "#5BA7FF", "$type": "color" },
      "royal-blue-700":   { "$value": "#437DC0", "$type": "color" },
      "lime-500":         { "$value": "#BFD732", "$type": "color" },
      "lime-700":         { "$value": "#8CC63F", "$type": "color" },
      "green-900":        { "$value": "#113033", "$type": "color" }
    },
    "neutral": {
      "$description": "Escala de grises para texto, bordes y fondos",
      "black":    { "$value": "#111111", "$type": "color" },
      "grey-900": { "$value": "#1B1F23", "$type": "color" },
      "grey-800": { "$value": "#3B4044", "$type": "color" },
      "grey-700": { "$value": "#5A5F63", "$type": "color" },
      "grey-600": { "$value": "#6E7277", "$type": "color" },
      "grey-500": { "$value": "#969BA0", "$type": "color" },
      "grey-400": { "$value": "#B5B5B5", "$type": "color" },
      "grey-300": { "$value": "#D9D9D9", "$type": "color" },
      "grey-200": { "$value": "#EEEEEE", "$type": "color" },
      "grey-100": { "$value": "#F5F5F5", "$type": "color" },
      "white":    { "$value": "#FFFFFF", "$type": "color" }
    },
    "surface": {
      "$description": "Fondos de pagina y superficies",
      "bg":                 { "$value": "#fafafa",  "$type": "color" },
      "june-surface":       { "$value": "#ffffff",  "$type": "color" },
      "card":               { "$value": "#ffffff",  "$type": "color" },
      "card-border":        { "$value": "#e0e0e0",  "$type": "color" },
      "card-head":          { "$value": "#f5f5f5",  "$type": "color" },
      "surface-alternative": { "$value": "#F5F5F5", "$type": "color" }
    },
    "accent": {
      "$description": "Paleta para fondos, cards y badges",
      "purple-900": { "$value": "#903085", "$type": "color" },
      "purple-600": { "$value": "#E47FF4", "$type": "color" },
      "orange-900":   { "$value": "#BE560B", "$type": "color" },
      "orange-500": { "$value": "#FFA235", "$type": "color" },
      "green-900":  { "$value": "#113033", "$type": "color" },
      "green-500":  { "$value": "#A9F3D0", "$type": "color" },
      "green-200":  { "$value": "#D3F7E9", "$type": "color" },
      "green-50":   { "$value": "#EFFAFA", "$type": "color" },
      "blue-900":   { "$value": "#151F2B", "$type": "color" },
      "blue-50":    { "$value": "#F5F9FF", "$type": "color" }
    },
    "state": {
      "$description": "Feedback visual: errores, exito y alertas",
      "error":    { "$value": "#E74131", "$type": "color" },
      "success":  { "$value": "#02A08B", "$type": "color" },
      "warning":  { "$value": "#FF8000", "$type": "color" },
      "error-bg": { "$value": "#FFF0F0", "$type": "color" }
    },
    "text-icon-border": {
      "$description": "Primitivos compartidos para texto, iconos y bordes",
      "positive": { "$value": "#111111", "$type": "color" },
      "negative": { "$value": "#FFFFFF", "$type": "color" },
      "disabled": { "$value": "#6E7277", "$type": "color" }
    },
    "brand": {
      "gx": {
        "$description": "GeneXus",
        "base":   { "$value": "#E02B58", "$type": "color" },
        "hover":  { "$value": "#D2285D", "$type": "color" },
        "on":     { "$value": "#FFFFFF", "$type": "color" },
        "accent": { "$value": "#e02b58", "$type": "color" },
        "text":   { "$value": "#E02B58", "$type": "color" }
      },
      "nx": {
        "$description": "Next",
        "base":   { "$value": "#5BA7FF", "$type": "color" },
        "hover":  { "$value": "#437DC0", "$type": "color" },
        "on":     { "$value": "#111111", "$type": "color" },
        "accent": { "$value": "#2878CD", "$type": "color" },
        "focus":  { "$value": "#437DC0", "$type": "color" },
        "text":   { "$value": "#5BA7FF", "$type": "color" }
      },
      "ge": {
        "$description": "GEAI",
        "base":   { "$value": "#BFD732", "$type": "color" },
        "hover":  { "$value": "#8CC63F", "$type": "color" },
        "on":     { "$value": "#111111", "$type": "color" },
        "accent": { "$value": "#BFD732", "$type": "color" },
        "text":   { "$value": "#BFD732", "$type": "color" }
      }
    },
    "dark": {
      "$description": "Overrides para dark mode (body.dm)",
      "bg":          { "$value": "#0d1015", "$type": "color" },
      "card":        { "$value": "#15181e", "$type": "color" },
      "card-border": { "$value": "#252830", "$type": "color" },
      "card-head":   { "$value": "#1c1f25", "$type": "color" },
      "black":       { "$value": "#eeeef0", "$type": "color" },
      "text":        { "$value": "#c8c8cc", "$type": "color", "$description": "10.8:1 AAA sobre #0d1015" },
      "brand-text": {
        "gx": { "$value": "#f06080", "$type": "color", "$description": "5.6:1 AA sobre #0d1015" },
        "nx": { "$value": "#7BBDFF", "$type": "color", "$description": "7.5:1 AAA sobre #0d1015" },
        "ge": { "$value": "#BFD732", "$type": "color", "$description": "11.7:1 AAA sobre #0d1015" }
      }
    }
  },
  "spacing": {
    "$description": "Escala de spacing — 14 niveles",
    "none": { "$value": "0px",  "$type": "dimension" },
    "0":  { "$value": "2px",   "$type": "dimension" },
    "1":  { "$value": "4px",   "$type": "dimension" },
    "2":  { "$value": "8px",   "$type": "dimension" },
    "3":  { "$value": "12px",  "$type": "dimension" },
    "4":  { "$value": "16px",  "$type": "dimension" },
    "5":  { "$value": "24px",  "$type": "dimension" },
    "6":  { "$value": "32px",  "$type": "dimension" },
    "7":  { "$value": "48px",  "$type": "dimension" },
    "8":  { "$value": "64px",  "$type": "dimension" },
    "9":  { "$value": "80px",  "$type": "dimension" },
    "10": { "$value": "128px", "$type": "dimension" },
    "11": { "$value": "172px", "$type": "dimension" },
    "12": { "$value": "240px", "$type": "dimension" }
  },
  "borderRadius": {
    "xs":   { "$value": "4px",   "$type": "dimension" },
    "sm":   { "$value": "6px",   "$type": "dimension" },
    "md":   { "$value": "8px",   "$type": "dimension" },
    "lg":   { "$value": "12px",  "$type": "dimension" },
    "xl":   { "$value": "16px",  "$type": "dimension" },
    "2xl":  { "$value": "24px",  "$type": "dimension" },
    "3xl":  { "$value": "32px",  "$type": "dimension" },
    "full": { "$value": "100px", "$type": "dimension" }
  },
  "fontFamily": {
    "display": { "$value": "'Graphik', 'Rubik', sans-serif", "$type": "fontFamily" },
    "body":    { "$value": "'Rubik', sans-serif",             "$type": "fontFamily" },
    "mono":    { "$value": "'SF Mono', 'Fira Code', monospace", "$type": "fontFamily" }
  },
  "typography": {
    "$description": "Escala tipografica — shorthand: weight size/line-height family",
    "title-1":      { "$value": { "fontWeight": 600, "fontSize": "46px", "lineHeight": "60px", "fontFamily": "{fontFamily.display}" }, "$type": "typography" },
    "title-2":      { "$value": { "fontWeight": 600, "fontSize": "36px", "lineHeight": "48px", "fontFamily": "{fontFamily.display}" }, "$type": "typography" },
    "title-3":      { "$value": { "fontWeight": 600, "fontSize": "26px", "lineHeight": "36px", "fontFamily": "{fontFamily.display}" }, "$type": "typography" },
    "title-4":      { "$value": { "fontWeight": 600, "fontSize": "20px", "lineHeight": "30px", "fontFamily": "{fontFamily.display}" }, "$type": "typography" },
    "title-5":      { "$value": { "fontWeight": 600, "fontSize": "17px", "lineHeight": "26px", "fontFamily": "{fontFamily.display}" }, "$type": "typography" },
    "highlight-l":  { "$value": { "fontWeight": 300, "fontSize": "26px", "lineHeight": "36px", "fontFamily": "{fontFamily.display}" }, "$type": "typography" },
    "highlight-m":  { "$value": { "fontWeight": 300, "fontSize": "20px", "lineHeight": "30px", "fontFamily": "{fontFamily.display}" }, "$type": "typography" },
    "highlight-s":  { "$value": { "fontWeight": 300, "fontSize": "17px", "lineHeight": "26px", "fontFamily": "{fontFamily.display}" }, "$type": "typography" },
    "body-m":       { "$value": { "fontWeight": 300, "fontSize": "17px", "lineHeight": "26px", "fontFamily": "{fontFamily.body}" }, "$type": "typography" },
    "body-m-strong":{ "$value": { "fontWeight": 500, "fontSize": "17px", "lineHeight": "26px", "fontFamily": "{fontFamily.body}" }, "$type": "typography" },
    "body-s":       { "$value": { "fontWeight": 300, "fontSize": "14px", "lineHeight": "22px", "fontFamily": "{fontFamily.body}" }, "$type": "typography" },
    "body-s-strong":{ "$value": { "fontWeight": 500, "fontSize": "14px", "lineHeight": "22px", "fontFamily": "{fontFamily.body}" }, "$type": "typography" },
    "body-xs":      { "$value": { "fontWeight": 300, "fontSize": "12px", "lineHeight": "20px", "fontFamily": "{fontFamily.body}" }, "$type": "typography" },
    "body-xs-strong":{ "$value": { "fontWeight": 500, "fontSize": "12px", "lineHeight": "20px", "fontFamily": "{fontFamily.body}" }, "$type": "typography" },
    "label":        { "$value": { "fontWeight": 500, "fontSize": "17px", "lineHeight": "26px", "fontFamily": "{fontFamily.body}" }, "$type": "typography" },
    "link":         { "$value": { "fontWeight": 300, "fontSize": "17px", "lineHeight": "17px", "fontFamily": "{fontFamily.body}" }, "$type": "typography" }
  },
  "shadow": {
    "$description": "Escala de elevacion",
    "xs":  { "$value": "0 1px 2px rgba(0,0,0,0.06)",                                  "$type": "shadow" },
    "sm":  { "$value": "0 1px 4px rgba(0,0,0,0.08), 0 1px 2px rgba(0,0,0,0.04)",      "$type": "shadow" },
    "md":  { "$value": "0 4px 12px rgba(0,0,0,0.10), 0 1px 3px rgba(0,0,0,0.06)",     "$type": "shadow" },
    "lg":  { "$value": "0 8px 24px rgba(0,0,0,0.12), 0 2px 6px rgba(0,0,0,0.06)",     "$type": "shadow" },
    "xl":  { "$value": "0 16px 48px rgba(0,0,0,0.14), 0 4px 12px rgba(0,0,0,0.08)",   "$type": "shadow" },
    "2xl": { "$value": "0 32px 64px rgba(0,0,0,0.18), 0 8px 20px rgba(0,0,0,0.10)",   "$type": "shadow" },
    "dark": {
      "$description": "Overrides dark mode — xs y sm son none",
      "xs":  { "$value": "none",                              "$type": "shadow" },
      "sm":  { "$value": "none",                              "$type": "shadow" },
      "md":  { "$value": "0 4px 12px rgba(0,0,0,0.40)",      "$type": "shadow" },
      "lg":  { "$value": "0 8px 24px rgba(0,0,0,0.45)",      "$type": "shadow" },
      "xl":  { "$value": "0 16px 48px rgba(0,0,0,0.50)",     "$type": "shadow" },
      "2xl": { "$value": "0 32px 64px rgba(0,0,0,0.55)",     "$type": "shadow" }
    }
  },
  "breakpoint": {
    "$description": "Valores de frame Figma + breakpoints de layout",
    "mobile-sm":   { "$value": "380px",  "$type": "dimension" },
    "mobile-lg":   { "$value": "428px",  "$type": "dimension" },
    "tablet-sm":   { "$value": "640px",  "$type": "dimension" },
    "tablet-lg":   { "$value": "768px",  "$type": "dimension" },
    "tablet":      { "$value": "640px",  "$type": "dimension", "$description": "< este valor → layout mobile" },
    "desktop":     { "$value": "760px",  "$type": "dimension", "$description": "< este valor → layout tablet" },
    "desktop-xs":  { "$value": "380px",  "$type": "dimension" },
    "desktop-s":   { "$value": "440px",  "$type": "dimension" },
    "desktop-m":   { "$value": "512px",  "$type": "dimension" },
    "desktop-l":   { "$value": "640px",  "$type": "dimension" },
    "desktop-xl":  { "$value": "760px",  "$type": "dimension" },
    "desktop-2xl": { "$value": "940px",  "$type": "dimension" },
    "desktop-3xl": { "$value": "1440px", "$type": "dimension" }
  },
  "zIndex": {
    "below":    { "$value": -1,  "$type": "number" },
    "base":     { "$value": 0,   "$type": "number" },
    "raised":   { "$value": 10,  "$type": "number", "$description": "Cards elevadas, dropdowns simples" },
    "dropdown": { "$value": 100, "$type": "number", "$description": "Menus, tooltips" },
    "sticky":   { "$value": 200, "$type": "number", "$description": "Topbar, sidebar" },
    "modal":    { "$value": 300, "$type": "number", "$description": "Dialogs, drawers" },
    "toast":    { "$value": 400, "$type": "number", "$description": "Notificaciones" },
    "top":      { "$value": 999, "$type": "number", "$description": "Skip links, overlays criticos" }
  },
  "motion": {
    "ease":          { "$value": "cubic-bezier(0.25, 0.1, 0.25, 1)", "$type": "cubicBezier" },
    "duration-fast": { "$value": "120ms", "$type": "duration" },
    "duration":      { "$value": "200ms", "$type": "duration" }
  },
  "overlay": {
    "$description": "Overlays y scrims",
    "dark":   { "$value": "rgba(0,0,0,0.55)", "$type": "color" },
    "medium": { "$value": "rgba(0,0,0,0.35)", "$type": "color" },
    "scrim":  { "$value": "rgba(0,0,0,0.30)", "$type": "color" }
  },
  "gradient": {
    "$description": "Gradientes reutilizables",
    "blue": { "$value": "linear-gradient(148deg, #11151C 18.5%, #5BA7FF 220.55%)", "$type": "gradient" }
  }
}
