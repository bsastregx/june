{
  "name": "@anthropic/june-ds",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/june-ds.js",
  "module": "./dist/june-ds.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/june-ds.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.json": "./src/tokens/tokens.json"
  },
  "files": [
    "dist",
    "src/tokens",
    "src/styles"
  ],
  "scripts": {
    "tokens": "node scripts/generate-tokens.mjs",
    "build": "npm run tokens && vite build && npm run build:css && tsc -p tsconfig.build.json",
    "build:css": "sass src/tokens/_all.scss dist/tokens.css --style=expanded --no-source-map",
    "dev": "vite build --watch",
    "fetch-illustrations": "node scripts/fetch-illustrations.mjs",
    "fetch-illustrations:all": "node scripts/fetch-illustrations.mjs --all",
    "illustrations": "node scripts/process-illustrations.mjs",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "peerDependencies": {
    "@genexus/kasstor-core": "^0.3.0",
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@genexus/vite-plugin-kasstor": "^0.3.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "lit": "^3.2.1",
    "playwright": "^1.58.2",
    "sass": "^1.83.0",
    "svgo": "^4.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@genexus/kasstor-core": "^0.3.0"
  }
}
